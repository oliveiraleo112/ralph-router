# Environment for Agrofel Dashboard backend
# Adjust placeholders to real values on the host or during deployment
CHATWOOT_URL=http://chatwoot_app:3000
CHATWOOT_ACCOUNT_ID=REPLACE_WITH_CHATWOOT_ACCOUNT_ID
REDIS_URL=redis://chatwoot_redis:6379
